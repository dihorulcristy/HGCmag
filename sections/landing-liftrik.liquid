<!-- ================================================================
     JAVASCRIPT — bundle selector, CTA, timer, sticky, FAQ
     ================================================================ -->
<script>
(function() {
  'use strict';

  // ========== BUNDLE SELECTOR ==========
  var bundles = document.querySelectorAll('.lt-bundle');
  var selectedQty = 3; // default: tratament complet

  bundles.forEach(function(b) {
    b.addEventListener('click', function() {
      bundles.forEach(function(x) { x.classList.remove('active'); });
      this.classList.add('active');
      selectedQty = parseInt(this.getAttribute('data-qty'), 10) || 1;

      // Update buy button text
      var btn = document.getElementById('ltBuyBtn');
      var price = this.getAttribute('data-price');
      if (btn && price) {
        btn.querySelector('span').textContent = 'Comandă acum la ' + price + ' RON';
      }
      // Update sticky
      var stickyPrice = document.querySelector('.lt-sticky-info .price');
      if (stickyPrice) {
        var wasValues = { 1: null, 3: '330 RON', 5: '550 RON' };
        var wasMarkup = wasValues[selectedQty] ? ' <span class="was">' + wasValues[selectedQty] + '</span>' : '';
        stickyPrice.innerHTML = price + ' RON' + wasMarkup;
      }
    });
  });

  // ========== BUY NOW ==========
  window.ltBuyNow = function() {
    var variantId = {{ product.selected_or_first_available_variant.id | json }};
    var btn = document.getElementById('ltBuyBtn');
    if (btn) {
      var originalText = btn.innerHTML;
      btn.innerHTML = '<span>Se procesează...</span>';
      btn.disabled = true;
    }

    fetch('/cart/clear.js', { method: 'POST' })
      .then(function() {
        return fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: variantId, quantity: selectedQty })
        });
      })
      .then(function() { window.location.href = '/checkout'; })
      .catch(function(err) {
        console.error(err);
        window.location.href = '/checkout';
      });
  };

  // ========== SCROLL TO BUY ==========
  window.ltScrollToBuy = function(e) {
    if (e) e.preventDefault();
    var target = document.getElementById('buy');
    if (target) {
      target.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  };

  // ========== COUNTDOWN (real, expiră la 23:59 azi) ==========
  function updateCountdown() {
    var now = new Date();
    var endOfDay = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 23, 59, 59);
    var diff = endOfDay - now;
    if (diff < 0) diff = 0;

    var h = Math.floor(diff / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);

    var pad = function(n) { return n < 10 ? '0' + n : n; };
    var el = document.getElementById('lt-countdown');
    if (el) el.textContent = pad(h) + ':' + pad(m) + ':' + pad(s);
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);

  // ========== STICKY CTA (pe mobile după scroll peste hero) ==========
  var sticky = document.getElementById('ltSticky');
  var buySection = document.getElementById('buy');

  function onScroll() {
    if (window.innerWidth > 820 || !sticky || !buySection) {
      if (sticky) sticky.classList.remove('visible');
      return;
    }
    var buyRect = buySection.getBoundingClientRect();
    var buyBottom = buyRect.bottom;
    // Apare când offer card-ul e complet scrollat sub fold
    if (buyBottom < 0) {
      sticky.classList.add('visible');
    } else {
      sticky.classList.remove('visible');
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll);

  // ========== FAQ ACCORDION ==========
  var faqs = document.querySelectorAll('.lt-faq-item');
  faqs.forEach(function(item) {
    var q = item.querySelector('.lt-faq-q');
    q.addEventListener('click', function() {
      var wasOpen = item.classList.contains('open');
      faqs.forEach(function(x) { x.classList.remove('open'); });
      if (!wasOpen) item.classList.add('open');
    });
  });

  // ========== STOCK COUNTER (descrește lent, real-looking) ==========
  // Pornește de la 37, scade cu 1 la fiecare 45-120 secunde, se oprește la 8
  var stockEl = document.getElementById('ltStockCount');
  if (stockEl) {
    var current = parseInt(stockEl.textContent, 10) || 37;
    function decrementStock() {
      if (current > 8) {
        current -= 1;
        stockEl.textContent = current;
      }
      setTimeout(decrementStock, 45000 + Math.random() * 75000);
    }
    setTimeout(decrementStock, 30000);
  }

})();
</script>

