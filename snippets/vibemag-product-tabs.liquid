{% comment %}
  VibeMag Product Description Tabs
  Tabs: Descriere, Specificații Tehnice, Cum Se Folosește
{% endcomment %}

<div class="vm-product-tabs">
  <div class="vm-tabs-nav">
    <button class="vm-tab-link is-active" data-tab="description" type="button">Descriere</button>
    <button class="vm-tab-link" data-tab="specs" type="button">Specificații Tehnice</button>
    <button class="vm-tab-link" data-tab="howto" type="button">Cum Se Folosește</button>
  </div>

  <div class="vm-tabs-content">
    <!-- Tab 1: Descriere -->
    <div class="vm-tab-pane is-active" id="vm-tab-description">
      <div class="vm-tab-description-content">
        {{ product.description }}
      </div>
    </div>

    <!-- Tab 2: Specificații Tehnice -->
    <div class="vm-tab-pane" id="vm-tab-specs">
      <div class="vm-specs-grid">
        <div class="vm-spec-row">
          <div class="vm-spec-label">Material</div>
          <div class="vm-spec-value">Plastic ABS de înaltă densitate</div>
        </div>
        <div class="vm-spec-row">
          <div class="vm-spec-label">Tehnologie</div>
          <div class="vm-spec-value">Terapie cu Vacuum & Masaj cu Role</div>
        </div>
        <div class="vm-spec-row">
          <div class="vm-spec-label">Niveluri intensitate</div>
          <div class="vm-spec-value">Reglabile (Viteză și Aspirație)</div>
        </div>
        <div class="vm-spec-row">
          <div class="vm-spec-label">Acumulator</div>
          <div class="vm-spec-value">Li-ion 800 mAh, Reîncărcabil USB</div>
        </div>
        <div class="vm-spec-row">
          <div class="vm-spec-label">Capete incluse</div>
          <div class="vm-spec-value">2 Capete interschimbabile (S & M)</div>
        </div>
        <div class="vm-spec-row">
          <div class="vm-spec-label">Dimensiuni</div>
          <div class="vm-spec-value">19 x 7 x 7 cm (Compact & Portabil)</div>
        </div>
        <div class="vm-spec-row">
          <div class="vm-spec-label">Conector</div>
          <div class="vm-spec-value">USB (Include stație de încărcare)</div>
        </div>
      </div>
    </div>

    <!-- Tab 3: Cum Se Folosește -->
    <div class="vm-tab-pane" id="vm-tab-howto">
      <div class="vm-steps-container">
        <div class="vm-step-item">
          <div class="vm-step-number">1</div>
          <div class="vm-step-content">
            <h4 class="vm-step-title">Pregătirea pielii</h4>
            <p class="vm-step-desc">Asigură-te că pielea este curată și aplică un ulei de corp sau anticelulitic pentru a facilita alunecarea aparatului și a maximiza efectul.</p>
          </div>
        </div>
        <div class="vm-step-item">
          <div class="vm-step-number">2</div>
          <div class="vm-step-content">
            <h4 class="vm-step-title">Alegerea capătului</h4>
            <p class="vm-step-desc">Folosește capătul cu o rolă pentru brațe și picioare, sau capătul cu două role pentru zone mai mari precum abdomenul sau coapsele.</p>
          </div>
        </div>
        <div class="vm-step-item">
          <div class="vm-step-number">3</div>
          <div class="vm-step-content">
            <h4 class="vm-step-title">Masajul activ</h4>
            <p class="vm-step-desc">Porneste aparatul și mișcă-l lent, prin glisare circulară sau lineară pe zona dorită, timp de 5-10 minute pe zi.</p>
          </div>
        </div>
        <div class="vm-step-item">
          <div class="vm-step-number">4</div>
          <div class="vm-step-content">
            <h4 class="vm-step-title">Finalizare</h4>
            <p class="vm-step-desc">Oprește aspirarea înainte de a ridica aparatul de pe piele. Curăță capătul după utilizare pentru a menține igiena optimă.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const tabLinks = document.querySelectorAll('.vm-tab-link');
    const tabPanes = document.querySelectorAll('.vm-tab-pane');

    tabLinks.forEach(link => {
      link.addEventListener('click', () => {
        const tabId = link.getAttribute('data-tab');

        // Remove active from all
        tabLinks.forEach(l => l.classList.remove('is-active'));
        tabPanes.forEach(p => p.classList.remove('is-active'));

        // Add active to current
        link.classList.add('is-active');
        document.getElementById(`vm-tab-${tabId}`).classList.add('is-active');
      });
    });
  });
</script>
