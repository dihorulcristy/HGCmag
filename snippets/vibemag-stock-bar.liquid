{%- comment -%}
  VibeMag Stock Urgency Bar
  Renders a subtle warning bar about limited stock.
  Usage: {% render 'vibemag-stock-bar' %}
{%- endcomment -%}

<div class="vm-stock-urgency" role="status" aria-label="Stoc limitat">
  <div class="vm-stock-urgency__inner">
    <div class="vm-stock-urgency__left">
      <svg class="vm-stock-urgency__icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2C12 2 7 8 7 12c0 2.76 2.24 5 5 5s5-2.24 5-5c0-4-5-10-5-10zm0 13c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z"/>
      </svg>
      <span>Stoc limitat — comandă acum pentru livrare rapidă</span>
    </div>
    <div class="vm-stock-urgency__right">
      Se termină repede
    </div>
  </div>
</div>
