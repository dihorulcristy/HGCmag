{%- comment -%}
  VibeMag Urgency & Scarcity Snippet
  Usage: {% render 'vibemag-urgency', product: product %}
  Renders low stock badge + viewer count badge for product pages.
{%- endcomment -%}

{%- liquid
  assign inventory_qty = product.selected_or_first_available_variant.inventory_quantity | default: 0
  assign inventory_policy = product.selected_or_first_available_variant.inventory_management
  assign show_low_stock = false
  if inventory_policy == 'shopify' and inventory_qty > 0 and inventory_qty <= 7
    assign show_low_stock = true
  endif
-%}

<div class="vm-urgency-strip" aria-live="polite">
  {%- if show_low_stock -%}
    <div class="vm-badge-stock" role="status">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
      </svg>
      <span>
        {%- if inventory_qty == 1 -%}
          {{ 'products.product.only_one_left' | t | default: 'Ultimul produs in stoc!' }}
        {%- else -%}
          {{
            'products.product.only_x_left'
            | t: quantity: inventory_qty
            | default: 'Doar '
            | append: inventory_qty
            | append: ' bucati in stoc!'
          }}
        {%- endif -%}
      </span>
    </div>
  {%- endif -%}

  <div class="vm-badge-viewers" role="status" aria-label="Utilizatori activi">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
      <circle cx="12" cy="12" r="3"/>
    </svg>
    <span id="vm-viewer-count">
      {%- assign viewer_seed = product.id | modulo: 23 | plus: 8 -%}
      {{ viewer_seed }}
      {{ 'products.product.people_viewing' | t | default: 'persoane vad acest produs acum' }}
    </span>
  </div>

  {%- if product.compare_at_price_max > product.price -%}
    <div class="vm-badge-sale-end" role="status">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
      </svg>
      <span>{{ 'products.product.sale_ends_soon' | t | default: 'Oferta limitata — pret redus activ' }}</span>
    </div>
  {%- endif -%}
</div>
