{%- comment -%}
  VibeMag Trust Bar Snippet
  Usage: {% render 'vibemag-trust-bar' %}
  Renders a horizontal strip of 4 trust signals.
{%- endcomment -%}

<div class="vm-trust-bar" role="region" aria-label="Why shop with us">
  <div class="vm-trust-bar__inner">

    <div class="vm-trust-item">
      <svg class="vm-trust-item__icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8l1 12a2 2 0 002 2h8a2 2 0 002-2L19 8"/>
      </svg>
      <span>{{ 'sections.trust_bar.free_shipping' | t | default: 'Livrare Gratuita' }}</span>
    </div>

    <div class="vm-trust-item">
      <svg class="vm-trust-item__icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
      </svg>
      <span>{{ 'sections.trust_bar.secure_payment' | t | default: 'Plata Securizata' }}</span>
    </div>

    <div class="vm-trust-item">
      <svg class="vm-trust-item__icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16 15v-1a4 4 0 00-4-4H8m0 0l3 3m-3-3l3-3m9 14V5a2 2 0 00-2-2H6a2 2 0 00-2 2v16l4-2 4 2 4-2 4 2z"/>
      </svg>
      <span>{{ 'sections.trust_bar.easy_returns' | t | default: 'Retur 30 Zile' }}</span>
    </div>

    <div class="vm-trust-item">
      <svg class="vm-trust-item__icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
      </svg>
      <span>{{ 'sections.trust_bar.rating' | t | default: '4.9★ Recenzii Verificate' }}</span>
    </div>

  </div>
</div>
