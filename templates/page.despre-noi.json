{
  "sections": {
    "main": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n  :root {\n    --teal: #2abfb0;\n    --teal-dark: #1fa89a;\n    --teal-light: #e8f8f7;\n    --teal-mid: #b2e8e4;\n    --dark: #1a2b32;\n    --text: #2d2d2d;\n    --muted: #6b7b80;\n    --bg: #f4f9f9;\n    --white: #ffffff;\n    --border: #e0eeec;\n  }\n\n  .about-us-wrapper {\n    font-family: 'Open Sans', sans-serif;\n    background: var(--white);\n    color: var(--text);\n    font-size: 15px;\n    line-height: 1.7;\n  }\n\n  /* ── HERO ── */\n  .about-us-wrapper .hero {\n    background: var(--dark);\n    padding: 72px 48px 64px;\n    text-align: center;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .about-us-wrapper .hero::before {\n    content: '';\n    position: absolute;\n    top: -60px; left: -60px;\n    width: 300px; height: 300px;\n    border-radius: 50%;\n    background: var(--teal);\n    opacity: 0.06;\n  }\n\n  .about-us-wrapper .hero::after {\n    content: '';\n    position: absolute;\n    bottom: -80px; right: -40px;\n    width: 360px; height: 360px;\n    border-radius: 50%;\n    background: var(--teal);\n    opacity: 0.05;\n  }\n\n  .about-us-wrapper .hero-eyebrow {\n    display: inline-block;\n    background: var(--teal);\n    color: #fff;\n    font-family: 'Montserrat', sans-serif;\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    padding: 5px 16px;\n    border-radius: 20px;\n    margin-bottom: 20px;\n  }\n\n  .about-us-wrapper .hero h1 {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 44px;\n    font-weight: 700;\n    color: #fff;\n    line-height: 1.15;\n    margin: 0 0 16px;\n  }\n\n  .about-us-wrapper .hero h1 span { color: var(--teal); }\n\n  .about-us-wrapper .hero-sub {\n    font-size: 15px;\n    color: rgba(255,255,255,0.65);\n    max-width: 520px;\n    margin: 0 auto 40px;\n    line-height: 1.8;\n  }\n\n  .about-us-wrapper .hero-stats {\n    display: flex;\n    justify-content: center;\n    gap: 0;\n    max-width: 640px;\n    margin: 0 auto;\n    border-radius: 10px;\n    overflow: hidden;\n    border: 0.5px solid rgba(255,255,255,0.08);\n  }\n\n  .about-us-wrapper .hero-stat {\n    flex: 1;\n    background: rgba(255,255,255,0.05);\n    padding: 20px 16px;\n    border-right: 0.5px solid rgba(255,255,255,0.08);\n    text-align: center;\n  }\n\n  .about-us-wrapper .hero-stat:last-child { border-right: none; }\n  .about-us-wrapper .hero-stat:first-child { background: var(--teal); }\n\n  .about-us-wrapper .stat-n {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 26px;\n    font-weight: 700;\n    color: #fff;\n    display: block;\n    line-height: 1;\n    margin-bottom: 5px;\n  }\n\n  .about-us-wrapper .stat-l {\n    font-size: 11px;\n    color: rgba(255,255,255,0.6);\n    letter-spacing: 0.3px;\n  }\n\n  .about-us-wrapper .hero-stat:first-child .stat-l { color: rgba(255,255,255,0.85); }\n\n  /* ── TRUST STRIP ── */\n  .about-us-wrapper .trust-strip {\n    background: var(--teal-light);\n    border-top: 2px solid var(--teal);\n    border-bottom: 1px solid var(--teal-mid);\n    display: flex;\n    justify-content: center;\n    gap: 40px;\n    padding: 14px 48px;\n    flex-wrap: wrap;\n  }\n\n  .about-us-wrapper .trust-item {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-family: 'Montserrat', sans-serif;\n    font-size: 12px;\n    font-weight: 600;\n    color: var(--dark);\n  }\n\n  .about-us-wrapper .trust-item svg {\n    width: 16px; height: 16px;\n    stroke: var(--teal);\n    fill: none;\n    stroke-width: 2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    flex-shrink: 0;\n  }\n\n  /* ── STORY ── */\n  .about-us-wrapper .story {\n    padding: 72px 48px;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 64px;\n    align-items: center;\n    background: var(--white);\n  }\n\n  .about-us-wrapper .section-eyebrow {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--teal);\n    margin-bottom: 12px;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n\n  .about-us-wrapper .section-eyebrow::after {\n    content: '';\n    display: block;\n    height: 2px;\n    width: 32px;\n    background: var(--teal);\n    border-radius: 2px;\n  }\n\n  .about-us-wrapper .section-title {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 30px;\n    font-weight: 700;\n    color: var(--dark);\n    line-height: 1.25;\n    margin-bottom: 20px;\n  }\n\n  .about-us-wrapper .story-body p {\n    font-size: 14px;\n    color: var(--muted);\n    line-height: 1.85;\n    margin-bottom: 16px;\n  }\n\n  .about-us-wrapper .story-body p:last-child { margin-bottom: 0; }\n\n  .about-us-wrapper .story-body strong { color: var(--dark); font-weight: 600; }\n\n  .about-us-wrapper .story-visual {\n    background: var(--teal-light);\n    border-radius: 12px;\n    border: 1px solid var(--teal-mid);\n    padding: 36px 32px;\n    display: flex;\n    flex-direction: column;\n    gap: 20px;\n  }\n\n  .about-us-wrapper .story-badge {\n    background: var(--white);\n    border-radius: 8px;\n    border: 1px solid var(--border);\n    padding: 18px 20px;\n    display: flex;\n    align-items: center;\n    gap: 14px;\n  }\n\n  .about-us-wrapper .badge-icon {\n    width: 44px; height: 44px;\n    background: var(--teal);\n    border-radius: 8px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n\n  .about-us-wrapper .badge-title {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 13px;\n    font-weight: 700;\n    color: var(--dark);\n    margin-bottom: 3px;\n  }\n\n  .about-us-wrapper .badge-sub {\n    font-size: 12px;\n    color: var(--muted);\n  }\n\n  /* ── DIFERENTIATOR ── */\n  .about-us-wrapper .diff {\n    background: var(--bg);\n    padding: 72px 48px;\n  }\n\n  .about-us-wrapper .diff-header {\n    text-align: center;\n    margin-bottom: 48px;\n  }\n\n  .about-us-wrapper .diff-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 16px;\n  }\n\n  .about-us-wrapper .diff-card {\n    background: var(--white);\n    border-radius: 10px;\n    border: 1px solid var(--border);\n    padding: 32px 28px;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .about-us-wrapper .diff-icon {\n    width: 48px; height: 48px;\n    background: var(--teal-light);\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin-bottom: 16px;\n    border: 1px solid var(--teal-mid);\n  }\n\n  .about-us-wrapper .diff-title {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    color: var(--dark);\n    margin-bottom: 10px;\n  }\n\n  .about-us-wrapper .diff-body {\n    font-size: 13px;\n    color: var(--muted);\n    line-height: 1.75;\n  }\n\n  /* ── VALUES ── */\n  .about-us-wrapper .values {\n    background: var(--white);\n    padding: 72px 48px;\n  }\n\n  .about-us-wrapper .values-grid {\n    display: grid;\n    grid-template-columns: repeat(2, 1fr);\n    gap: 14px;\n  }\n\n  .about-us-wrapper .value-card {\n    background: var(--bg);\n    border-radius: 10px;\n    border: 1px solid var(--border);\n    padding: 24px 28px;\n    display: flex;\n    gap: 16px;\n    align-items: flex-start;\n  }\n\n  .about-us-wrapper .value-icon {\n    width: 40px; height: 40px;\n    background: var(--teal);\n    border-radius: 8px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n\n  .about-us-wrapper .value-title {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 13px;\n    font-weight: 700;\n    color: var(--dark);\n    margin-bottom: 5px;\n  }\n\n  .about-us-wrapper .value-body {\n    font-size: 13px;\n    color: var(--muted);\n    line-height: 1.7;\n  }\n\n  /* ── QUOTE BANNER ── */\n  .about-us-wrapper .quote-banner {\n    background: var(--teal);\n    padding: 56px 48px;\n    text-align: center;\n  }\n\n  .about-us-wrapper .quote-text {\n    font-family: 'Montserrat', sans-serif;\n    font-size: 26px;\n    font-weight: 700;\n    color: #fff;\n    line-height: 1.35;\n    max-width: 680px;\n    margin: 0 auto 16px;\n  }\n\n  .about-us-wrapper .quote-sub {\n    font-size: 14px;\n    color: rgba(255,255,255,0.8);\n    max-width: 480px;\n    margin: 0 auto 28px;\n  }\n\n  .about-us-wrapper .quote-btn {\n    display: inline-block;\n    background: var(--white);\n    color: var(--teal-dark);\n    font-family: 'Montserrat', sans-serif;\n    font-size: 12px;\n    font-weight: 700;\n    letter-spacing: 1px;\n    text-transform: uppercase;\n    text-decoration: none;\n    padding: 13px 32px;\n    border-radius: 4px;\n  }\n\n  /* ── FOOTER TRUST ── */\n  .about-us-wrapper .footer-trust {\n    background: var(--dark);\n    padding: 28px 48px;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 40px;\n    flex-wrap: wrap;\n  }\n\n  .about-us-wrapper .ft-item {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-family: 'Montserrat', sans-serif;\n    font-size: 11px;\n    font-weight: 600;\n    color: rgba(255,255,255,0.55);\n    letter-spacing: 0.5px;\n  }\n\n  .about-us-wrapper .ft-dot {\n    width: 5px; height: 5px;\n    border-radius: 50%;\n    background: var(--teal);\n    flex-shrink: 0;\n  }\n\n  @media (max-width: 768px) {\n    .about-us-wrapper .hero { padding: 48px 20px 40px; }\n    .about-us-wrapper .hero h1 { font-size: 28px; }\n    .about-us-wrapper .hero-stats { flex-wrap: wrap; }\n    .about-us-wrapper .trust-strip { gap: 16px; padding: 12px 20px; }\n    .about-us-wrapper .story { grid-template-columns: 1fr; padding: 48px 20px; gap: 32px; }\n    .about-us-wrapper .diff { padding: 48px 20px; }\n    .about-us-wrapper .diff-grid { grid-template-columns: 1fr; }\n    .about-us-wrapper .values { padding: 48px 20px; }\n    .about-us-wrapper .values-grid { grid-template-columns: 1fr; }\n    .about-us-wrapper .quote-banner { padding: 40px 20px; }\n    .about-us-wrapper .quote-text { font-size: 20px; }\n    .about-us-wrapper .footer-trust { padding: 20px; gap: 16px; }\n    .about-us-wrapper .hero h1 br { display: none; }\n  }\n</style>\n\n<div class=\"about-us-wrapper\">\n\n  <!-- HERO -->\n  <section class=\"hero\">\n    <div class=\"hero-eyebrow\">Despre VibeMag</div>\n    <h1>Calitate Europeană.<br><span>Livrată în România.</span></h1>\n    <p class=\"hero-sub\">Suntem un brand românesc care aduce produse premium fabricate în Spania — nu din China. Calitate reală, selecție atentă, suport dedicat.</p>\n    <div class=\"hero-stats\">\n      <div class=\"hero-stat\">\n        <span class=\"stat-n\">500+</span>\n        <span class=\"stat-l\">Produse disponibile</span>\n      </div>\n      <div class=\"hero-stat\">\n        <span class=\"stat-n\">4.8★</span>\n        <span class=\"stat-l\">Rating clienți</span>\n      </div>\n      <div class=\"hero-stat\">\n        <span class=\"stat-n\">2–5</span>\n        <span class=\"stat-l\">Zile livrare</span>\n      </div>\n      <div class=\"hero-stat\">\n        <span class=\"stat-n\">14</span>\n        <span class=\"stat-l\">Zile retur</span>\n      </div>\n    </div>\n  </section>\n\n  <!-- TRUST STRIP -->\n  <div class=\"trust-strip\">\n    <div class=\"trust-item\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n      Suport 24/7\n    </div>\n    <div class=\"trust-item\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><rect x=\"1\" y=\"4\" width=\"22\" height=\"16\" rx=\"2\" stroke-width=\"2\"/><line x1=\"1\" y1=\"10\" x2=\"23\" y2=\"10\" stroke-width=\"2\"/></svg>\n      Plată Securizată\n    </div>\n    <div class=\"trust-item\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><path d=\"M5 12h14M12 5l7 7-7 7\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n      Livrare 2–5 Zile\n    </div>\n    <div class=\"trust-item\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><polyline points=\"1 4 1 10 7 10\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M3.51 15a9 9 0 102.13-9.36L1 10\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n      Retur 14 Zile\n    </div>\n  </div>\n\n  <!-- STORY -->\n  <section class=\"story\">\n    <div>\n      <div class=\"section-eyebrow\">Povestea noastră</div>\n      <h2 class=\"section-title\">De ce am creat VibeMag</h2>\n      <div class=\"story-body\">\n        <p>VibeMag a pornit dintr-o observație simplă: <strong>majoritatea magazinelor online din România importă produse ieftine din Asia</strong>, le ambalează frumos și le vând la prețuri umflate.</p>\n        <p>Am ales altfel. Colaborăm exclusiv cu <strong>InnovaGoods</strong> — unul dintre cei mai mari furnizori europeni de produse inovatoare, cu producție și depozite în <strong>Spania</strong>. Standarde europene reale, materiale de calitate, durabilitate testată.</p>\n        <p>Suntem un business românesc, construit cu respect față de cumpărător. Fiecare produs din magazin a fost ales manual — dacă nu l-am cumpăra noi înșine, nu îl vindem.</p>\n      </div>\n    </div>\n    <div class=\"story-visual\">\n      <div class=\"story-badge\">\n        <div class=\"badge-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><circle cx=\"12\" cy=\"12\" r=\"10\" stroke-width=\"2\"/><path d=\"M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z\" stroke-width=\"2\"/></svg>\n        </div>\n        <div>\n          <div class=\"badge-title\">Furnizor: InnovaGoods, Spania</div>\n          <div class=\"badge-sub\">Producție și standarde 100% europene</div>\n        </div>\n      </div>\n      <div class=\"story-badge\">\n        <div class=\"badge-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><path d=\"M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z\" stroke-width=\"2\"/><polyline points=\"9 22 9 12 15 12 15 22\" stroke-width=\"2\"/></svg>\n        </div>\n        <div>\n          <div class=\"badge-title\">Brand înregistrat în România</div>\n          <div class=\"badge-sub\">HGC Capital S.R.L. — conform ANPC & GDPR</div>\n        </div>\n      </div>\n      <div class=\"story-badge\">\n        <div class=\"badge-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><path d=\"M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z\" stroke-width=\"2\"/></svg>\n        </div>\n        <div>\n          <div class=\"badge-title\">Selecție manuală</div>\n          <div class=\"badge-sub\">Fiecare produs verificat înainte de publicare</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- DIFFERENTIATORS -->\n  <section class=\"diff\">\n    <div class=\"diff-header\">\n      <div class=\"section-eyebrow\">Ce ne diferențiază</div>\n      <h2 class=\"section-title\" style=\"text-align:center\">De ce VibeMag, nu altcineva</h2>\n    </div>\n    <div class=\"diff-grid\">\n      <div class=\"diff-card\">\n        <div class=\"diff-num\">01</div>\n        <div class=\"diff-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><circle cx=\"12\" cy=\"12\" r=\"10\" stroke-width=\"2\"/><path d=\"M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z\" stroke-width=\"2\"/></svg>\n        </div>\n        <div class=\"diff-title\">Produse fabricate în Spania, nu în China</div>\n        <div class=\"diff-body\">Furnizorul nostru exclusiv, InnovaGoods, produce în Europa. Asta înseamnă materiale superioare, durabilitate reală și standarde de siguranță europene — nu copii ieftine.</div>\n      </div>\n      <div class=\"diff-card\">\n        <div class=\"diff-num\">02</div>\n        <div class=\"diff-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><path d=\"M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2\" stroke-width=\"2\"/><circle cx=\"9\" cy=\"7\" r=\"4\" stroke-width=\"2\"/><path d=\"M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75\" stroke-width=\"2\"/></svg>\n        </div>\n        <div class=\"diff-title\">Brand românesc responsabil</div>\n        <div class=\"diff-body\">Suntem înregistrați în România sub HGC Capital S.R.L. Respectăm legislația ANPC, oferim garanțiile legale și suntem transparenți cu fiecare client.</div>\n      </div>\n      <div class=\"diff-card\">\n        <div class=\"diff-num\">03</div>\n        <div class=\"diff-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><polyline points=\"9 11 12 14 22 4\" stroke-width=\"2\"/><path d=\"M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11\" stroke-width=\"2\"/></svg>\n        </div>\n        <div class=\"diff-title\">Selecție atentă, nu catalog la gramadă</div>\n        <div class=\"diff-body\">Nu publicăm mii de produse aleatorii. Fiecare articol din VibeMag a trecut printr-un filtru de utilitate reală, calitate verificată și raport corect preț–valoare.</div>\n      </div>\n    </div>\n  </section>\n\n  <!-- VALUES -->\n  <section class=\"values\">\n    <div class=\"values-header\">\n      <div class=\"section-eyebrow\">Valorile noastre</div>\n      <h2 class=\"section-title\">Cum lucrăm</h2>\n    </div>\n    <div class=\"values-grid\">\n      <div class=\"value-card\">\n        <div class=\"value-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </div>\n        <div>\n          <div class=\"value-title\">Calitate verificată înainte de expediere</div>\n          <div class=\"value-body\">Fiecare comandă este procesată cu grijă. Dacă produsul nu corespunde, returnezi în 14 zile fără întrebări și primești banii înapoi integral.</div>\n        </div>\n      </div>\n      <div class=\"value-card\">\n        <div class=\"value-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><circle cx=\"12\" cy=\"12\" r=\"10\" stroke-width=\"2\"/><path d=\"M12 6v6l4 2\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </div>\n        <div>\n          <div class=\"value-title\">Livrare rapidă și urmăribilă</div>\n          <div class=\"value-body\">Livrăm în 2–5 zile lucrătoare. Primești numărul de urmărire imediat după expediere. Transport gratuit la comenzi peste 199 RON.</div>\n        </div>\n      </div>\n      <div class=\"value-card\">\n        <div class=\"value-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><path d=\"M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </div>\n        <div>\n          <div class=\"value-title\">Suport real, nu automat</div>\n          <div class=\"value-body\">Când ne contactezi, răspunde o persoană reală în maxim 2 ore. Suntem disponibili 7 zile din 7 pe email și chat.</div>\n        </div>\n      </div>\n      <div class=\"value-card\">\n        <div class=\"value-icon\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\"><line x1=\"12\" y1=\"1\" x2=\"12\" y2=\"23\" stroke-width=\"2\"/><path d=\"M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6\" stroke-width=\"2\"/></svg>\n        </div>\n        <div>\n          <div class=\"value-title\">Prețuri corecte, transparente</div>\n          <div class=\"value-body\">Prețul pe care îl vezi include tot — nu ascundem taxe la checkout. Reducerile afișate sunt reale față de prețul de listă al furnizorului.</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- QUOTE BANNER -->\n  <section class=\"quote-banner\">\n    <div class=\"quote-text\">„Nu vindem ce e ieftin.<br>Vindem ce merită cumpărat.\"</div>\n    <p class=\"quote-sub\">La VibeMag, standardul nu e prețul — e valoarea pe care o primești. Produse europene, livrare rapidă, suport dedicat.</p>\n    <a href=\"/collections/all\" class=\"quote-btn\">Descoperă Colecția</a>\n  </section>\n\n  <!-- FOOTER TRUST -->\n  <div class=\"footer-trust\">\n    <div class=\"ft-item\"><div class=\"ft-dot\"></div> HGC Capital S.R.L. — România</div>\n    <div class=\"ft-item\"><div class=\"ft-dot\"></div> Furnizor InnovaGoods — Spania</div>\n    <div class=\"ft-item\"><div class=\"ft-dot\"></div> ANPC conform</div>\n    <div class=\"ft-item\"><div class=\"ft-dot\"></div> GDPR conform</div>\n    <div class=\"ft-item\"><div class=\"ft-dot\"></div> Plăți securizate</div>\n  </div>\n\n</div>\n"
      }
    }
  },
  "order": [
    "main"
  ]
}
