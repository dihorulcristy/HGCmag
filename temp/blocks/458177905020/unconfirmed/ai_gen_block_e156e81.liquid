{% doc %}
  @prompt
    Modify the product card price display so that the original/compare-at price (full price, not crossed out) appears on top in a smaller font size, and the sale/discounted price appears below it in a larger, bold font. Reverse this order: full price on top (smaller, normal weight), sale price below (larger, bold). Apply this to the featured collection product cards.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-card-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    text-decoration: none;
    color: inherit;
  }

  .ai-product-card-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-product-card-image-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_ratio }};
    overflow: hidden;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-product-card-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-product-card-{{ ai_gen_id }}:hover .ai-product-card-image-{{ ai_gen_id }} img {
    transform: scale(1.05);
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-card-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-product-card-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-product-card-vendor-{{ ai_gen_id }} {
    font-size: {{ block.settings.vendor_font_size }}px;
    color: {{ block.settings.vendor_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 500;
  }

  .ai-product-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: {{ block.settings.title_font_weight }};
    line-height: 1.3;
    margin: 0;
  }

  .ai-product-card-price-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-product-card-compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_font_size }}px;
    color: {{ block.settings.compare_price_color }};
    font-weight: 400;
    text-decoration: line-through;
    opacity: 0.7;
  }

  .ai-product-card-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 700;
  }

  .ai-product-card-price-{{ ai_gen_id }}.ai-product-card-price-on-sale-{{ ai_gen_id }} {
    color: {{ block.settings.sale_price_color }};
  }

  .ai-product-card-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
  }

  @media screen and (max-width: 749px) {
    .ai-product-card-wrapper-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<a
  href="{{ block.settings.product.url }}"
  class="ai-product-card-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-product-card-wrapper-{{ ai_gen_id }}">
    <div class="ai-product-card-image-{{ ai_gen_id }}">
      {% if block.settings.product.featured_image %}
        <img
          src="{{ block.settings.product.featured_image | image_url: width: 800 }}"
          alt="{{ block.settings.product.featured_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.product.featured_image.width }}"
          height="{{ block.settings.product.featured_image.height }}"
        >
      {% else %}
        <div class="ai-product-card-image-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
        {% if block.settings.product == blank %}
          <div class="ai-product-card-empty-state-{{ ai_gen_id }}">
            Next, select a product
          </div>
        {% endif %}
      {% endif %}

      {% if block.settings.show_sale_badge and block.settings.product.compare_at_price > block.settings.product.price %}
        <div class="ai-product-card-badge-{{ ai_gen_id }}">
          {{ block.settings.sale_badge_text }}
        </div>
      {% endif %}
    </div>

    <div class="ai-product-card-info-{{ ai_gen_id }}">
      {% if block.settings.show_vendor and block.settings.product.vendor %}
        <div class="ai-product-card-vendor-{{ ai_gen_id }}">
          {{ block.settings.product.vendor }}
        </div>
      {% endif %}

      {% if block.settings.product.title %}
        <h3 class="ai-product-card-title-{{ ai_gen_id }}">
          {{ block.settings.product.title }}
        </h3>
      {% endif %}

      {% if block.settings.product.price %}
        <div class="ai-product-card-price-wrapper-{{ ai_gen_id }}">
          {% if block.settings.product.compare_at_price > block.settings.product.price %}
            <div class="ai-product-card-compare-price-{{ ai_gen_id }}">
              {{ block.settings.product.compare_at_price | money }}
            </div>
            <div class="ai-product-card-price-{{ ai_gen_id }} ai-product-card-price-on-sale-{{ ai_gen_id }}">
              {{ block.settings.product.price | money }}
            </div>
          {% else %}
            <div class="ai-product-card-price-{{ ai_gen_id }}">
              {{ block.settings.product.price | money }}
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</a>

{% schema %}
{
  "name": "Product card",
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        {
          "value": "1/1",
          "label": "Square (1:1)"
        },
        {
          "value": "3/4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "4/3",
          "label": "Landscape (4:3)"
        },
        {
          "value": "16/9",
          "label": "Wide (16:9)"
        }
      ],
      "default": "1/1"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Sale badge"
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "Show sale badge",
      "default": true
    },
    {
      "type": "text",
      "id": "sale_badge_text",
      "label": "Badge text",
      "default": "Sale"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge background",
      "default": "#00C5B3"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "badge_border_radius",
      "label": "Badge border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Vendor"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "range",
      "id": "vendor_font_size",
      "label": "Font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "vendor_color",
      "label": "Color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#0D1B2A"
    },
    {
      "type": "header",
      "content": "Price"
    },
    {
      "type": "range",
      "id": "compare_price_font_size",
      "label": "Compare price font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "compare_price_color",
      "label": "Compare price color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "price_font_size",
      "label": "Sale price font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Regular price color",
      "default": "#0D1B2A"
    },
    {
      "type": "color",
      "id": "sale_price_color",
      "label": "Sale price color",
      "default": "#00C5B3"
    }
  ],
  "presets": [
    {
      "name": "Product card"
    }
  ]
}
{% endschema %}