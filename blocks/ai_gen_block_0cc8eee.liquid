{% comment %} VibeMag — Reviews Summary Block {% endcomment %}

<style>
.vm-reviews-wrap {
  font-family: var(--font-body-family, 'DM Sans', sans-serif);
  padding: 48px 0 32px;
  border-top: 1px solid #e0eeec;
}

.vm-reviews-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
}

.vm-reviews-title {
  font-family: var(--font-heading-family, 'Inter', sans-serif);
  font-size: 20px;
  font-weight: 700;
  color: #1a2b32;
}

.vm-reviews-summary {
  display: flex;
  align-items: center;
  gap: 32px;
  background: #f4f9f9;
  border: 1px solid #e0eeec;
  border-radius: 10px;
  padding: 24px 28px;
}

.vm-rating-big {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}

.vm-rating-num {
  font-family: var(--font-heading-family, 'Inter', sans-serif);
  font-size: 48px;
  font-weight: 700;
  color: #1a2b32;
  line-height: 1;
}

.vm-stars {
  display: flex;
  gap: 3px;
}

.vm-star {
  width: 18px;
  height: 18px;
  fill: #2abfb0;
}

.vm-star.half {
  fill: url(#half-grad);
}

.vm-star.empty {
  fill: #e0eeec;
}

.vm-rating-count {
  font-size: 12px;
  color: #6b7b80;
  font-family: var(--font-body-family, 'DM Sans', sans-serif);
  white-space: nowrap;
}

.vm-divider {
  width: 1px;
  height: 60px;
  background: #e0eeec;
  flex-shrink: 0;
}

.vm-reviews-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.vm-bar-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.vm-bar-label {
  font-size: 12px;
  color: #6b7b80;
  width: 20px;
  text-align: right;
  flex-shrink: 0;
  font-family: var(--font-body-family, 'DM Sans', sans-serif);
}

.vm-bar-track {
  flex: 1;
  height: 6px;
  background: #e0eeec;
  border-radius: 3px;
  overflow: hidden;
}

.vm-bar-fill {
  height: 100%;
  background: #2abfb0;
  border-radius: 3px;
}

.vm-bar-pct {
  font-size: 11px;
  color: #9aa5a8;
  width: 28px;
  text-align: right;
  flex-shrink: 0;
  font-family: var(--font-body-family, 'DM Sans', sans-serif);
}

.vm-reviews-cta {
  margin-top: 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}

.vm-cta-text {
  font-size: 13px;
  color: #6b7b80;
  font-family: var(--font-body-family, 'DM Sans', sans-serif);
}

.vm-btn-review {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #2abfb0;
  color: #fff;
  font-family: var(--font-heading-family, 'Inter', sans-serif);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  padding: 11px 24px;
  border-radius: 4px;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: background 0.2s;
}

.vm-btn-review:hover {
  background: #1fa89a;
  color: #fff;
}

.vm-btn-review svg {
  width: 14px;
  height: 14px;
  stroke: #fff;
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.vm-verified-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: #fff;
  border: 1px solid #e0eeec;
  border-radius: 20px;
  padding: 5px 12px;
  font-size: 11px;
  color: #6b7b80;
  font-family: var(--font-body-family, 'DM Sans', sans-serif);
}

.vm-verified-badge svg {
  width: 12px;
  height: 12px;
  stroke: #2abfb0;
  fill: none;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}

@media (max-width: 640px) {
  .vm-reviews-summary {
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    padding: 20px;
  }
  .vm-divider { display: none; }
  .vm-reviews-right { width: 100%; }
  .vm-rating-big { flex-direction: row; align-items: baseline; gap: 12px; }
  .vm-rating-num { font-size: 36px; }
}
</style>

<div class="vm-reviews-wrap">

  <div class="vm-reviews-header">
    <h2 class="vm-reviews-title">Recenzii clienți</h2>
    <div class="vm-verified-badge">
      <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
      Recenzii verificate
    </div>
  </div>

  <div class="vm-reviews-summary">

    <div class="vm-rating-big">
      <div class="vm-rating-num">4.5</div>
      <div class="vm-stars">
        <svg viewBox="0 0 24 24" class="vm-star"><defs><linearGradient id="half-grad"><stop offset="50%" stop-color="#2abfb0"/><stop offset="50%" stop-color="#e0eeec"/></linearGradient></defs><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <svg viewBox="0 0 24 24" class="vm-star"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <svg viewBox="0 0 24 24" class="vm-star"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <svg viewBox="0 0 24 24" class="vm-star"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <svg viewBox="0 0 24 24" class="vm-star half"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </div>
      <div class="vm-rating-count">25 recenzii</div>
    </div>

    <div class="vm-divider"></div>

    <div class="vm-reviews-right">
      <div class="vm-bar-row">
        <span class="vm-bar-label">5★</span>
        <div class="vm-bar-track"><div class="vm-bar-fill" style="width:68%"></div></div>
        <span class="vm-bar-pct">68%</span>
      </div>
      <div class="vm-bar-row">
        <span class="vm-bar-label">4★</span>
        <div class="vm-bar-track"><div class="vm-bar-fill" style="width:20%"></div></div>
        <span class="vm-bar-pct">20%</span>
      </div>
      <div class="vm-bar-row">
        <span class="vm-bar-label">3★</span>
        <div class="vm-bar-track"><div class="vm-bar-fill" style="width:8%"></div></div>
        <span class="vm-bar-pct">8%</span>
      </div>
      <div class="vm-bar-row">
        <span class="vm-bar-label">2★</span>
        <div class="vm-bar-track"><div class="vm-bar-fill" style="width:3%"></div></div>
        <span class="vm-bar-pct">3%</span>
      </div>
      <div class="vm-bar-row">
        <span class="vm-bar-label">1★</span>
        <div class="vm-bar-track"><div class="vm-bar-fill" style="width:1%"></div></div>
        <span class="vm-bar-pct">1%</span>
      </div>
    </div>

  </div>

  <div class="vm-reviews-cta">
    <span class="vm-cta-text">Ai cumpărat acest produs? Spune-ne părerea ta.</span>
    <a href="mailto:client@vibemag.ro?subject=Recenzie produs" class="vm-btn-review">
      <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      Lasă o recenzie
    </a>
  </div>

</div>

